    <name>json-request-response-splitting</name>
    <vendor>ahmad-arbeed</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.ahmadarbeed.jsonrequestresponsesplitting.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="com.github.ahmadarbeed.jsonrequestresponsesplitting.startup.MyProjectActivity" />
    </extensions>
</idea-plugin>
